GEMINI_API_KEY=your_api_key_here

# 使用する Gemini モデル（任意・デフォルトは gemini-2.5-flash）
# 例: gemini-2.5-flash / gemini-2.5-flash-lite / gemini-2.0-flash
# GEMINI_MODEL=gemini-2.5-flash

# 採点用モデル（任意・デフォルトは gemini-2.5-flash-lite）
# GEMINI_GRADE_MODEL=gemini-2.5-flash-lite

# AI 機能（英訳・採点）のアクセスコード。
# これを設定すると公開環境（Vercel）でも、合言葉を入力した人だけ AI 機能を使える。
# 未設定の場合、公開環境では AI 機能は無効（ローカル開発時のみ利用可）。
# Vercel ではダッシュボードの Environment Variables に設定すること。
# APP_ACCESS_CODE=your_secret_passphrase
